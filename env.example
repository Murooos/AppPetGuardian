# ========================================
# Configurações do Banco de Dados PostgreSQL
# ========================================

# Opção 1: Usar DATABASE_URL (recomendado para Render.com)
DATABASE_URL=postgresql://usuario:senha@host:porta/database

# Opção 2: Usar variáveis individuais (alternativa)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=petguardian
# DB_USER=usuario
# DB_PASSWORD=senha

# ========================================
# Autenticação
# ========================================
# Chave secreta para JWT (gere uma chave segura em produção)
# Use: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=sua_chave_secreta_super_segura_aqui

# ========================================
# CORS (Permissões de Origem)
# ========================================
# URLs permitidas para CORS (separadas por vírgula)
# Para desenvolvimento: *
# Para produção: https://seu-site.netlify.app,https://www.seu-site.com
ALLOWED_ORIGINS=*

# ========================================
# Variáveis Obsoletas (Oracle - Remover)
# ========================================
# Estas variáveis NÃO são mais necessárias após migração para PostgreSQL:
# ORACLE_DSN
# ORACLE_USER
# ORACLE_PASSWORD
# ORACLE_CLIENT_LIB_DIR
# LD_LIBRARY_PATH

